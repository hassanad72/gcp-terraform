# Local Terraform working directories and downloaded providers
**/.terraform/*

# Terraform state can contain sensitive infrastructure data
*.tfstate
*.tfstate.*
state-before-migration*.json

# Saved Terraform execution plans
*.tfplan
tfplan

# Terraform crash logs
crash.log
crash.*.log

# Local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI configuration and credentials
.terraformrc
terraform.rc

# Local environment and secret files
.env
.env.*

# Common editor and operating-system files
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
